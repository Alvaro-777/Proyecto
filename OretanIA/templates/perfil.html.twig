{% extends 'base.html.twig' %}

{% block title %}Perfil{% endblock %}

{% block head %}
    <link rel="stylesheet" href="{{ asset('css/perfil.css') }}?v=1.1">
{% endblock %}

{% block cabecera %}Perfil de Usuario{% endblock %}

{% block body %}

    <section id="profile-error-board">

        {% for flashMessage in app.session.flashbag.get('error') %}

            <div id="err-{{ loop.index0 }}" class="error-notice">

                {{ flashMessage }}

                <button class="close-button"
                        onclick="document.getElementById('err-{{ loop.index0 }}').remove();">

                    ✕

                </button>

            </div>

        {% endfor %}

    </section>



    <section id="profile-header">
        <article class="profile-card">
            <div class="profile-avatar">
                <div class="avatar-wrapper">
                    {% if user and user.fotoPerfil %}
                        <img
                                class="profile-avatar-img"
                                src="{{ asset('uploads/perfiles/' ~ user.fotoPerfil) }}"
                                alt="Foto de perfil">
                    {% elseif user %}
                        <div class="avatar-circle">
                            {{ user.nombre|first }}{{ user.apellido|first }}
                        </div>
                    {% endif %}

                    {% if user %}
                        <form
                                action="{{ path('perfil_foto_upload') }}"
                                method="post"
                                enctype="multipart/form-data"
                                class="avatar-upload-form">

                            <label class="avatar-upload-button">
                                Cambiar
                                <input
                                        type="file"
                                        name="foto"
                                        accept="image/png,image/jpeg,image/webp"
                                        onchange="this.form.submit()">
                            </label>

                        </form>
                    {% endif %}

                </div>

            </div>



            <div class="profile-info">

                <div class="profile-title-row">

                    <h1>{{ user.nombre }} {{ user.apellido }}</h1>

                    <a class="edit-profile-button"
                       href="{{ path('perfil_configuracion') }}">

                        Editar cuenta

                    </a>

                </div>



                <ul class="profile-data">

                    <li>
                        <img src="{{ asset('imagenes/icon-mail.png') }}">
                        <span>Email</span>
                        <strong>{{ user.correo }}</strong>
                    </li>

                    <li>
                        <img src="{{ asset('imagenes/icon-date.png') }}">
                        <span>Registro</span>
                        <strong>{{ user.fechaRegistro | date('d/m/Y') }}</strong>
                    </li>

                    <li>
                        <img src="{{ asset('imagenes/icon-credit.png') }}">
                        <span>Créditos</span>
                        <strong>{{ user.creditos }}</strong>
                    </li>

                </ul>

            </div>


        </article>

    </section>

    <section id="profile-histories">
        <header>
            {# Añadimos la clase base 'table-tab' para facilitar el estilado #}
            <h2 class="table-tab active-table-tab" id="tab-usos">
                Historial de Uso
            </h2>
            <h2 class="table-tab inactive-table-tab" id="tab-pagos">
                Historial de Pago
            </h2>
        </header>

        <article id="profile-use-history" class="history-card">
            <table id="profile-use-history-table">
                <thead>
                    <tr>
                        <th>IA</th>
                        <th>Archivo</th>
                        <th>Texto</th>
                        <th>Fecha</th>
                    </tr>
                </thead>
                <tbody>
                {% for uso in historialUso %}
                    <tr>
                        <td>{{ uso.ia.nombre }}</td>
                        <td>{{ uso.archivo.nombre ?? "Ninguno" }}</td>
                        <td>{{ uso.textoInput ?? "Ninguno" }}</td>
                        <td>{{ uso.fecha | date("d/m/Y H:i") }}</td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="no-data-notice">
                            No has usado ninguna IA aún.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </article>

        <article class="inactive-table" id="profile-pay-history">
            <table id="profile-pay-history-table">
                <thead>
                    <tr>
                        <th class="slim">Válido</th>
                        <th>Método</th>
                        <th>Fecha</th>
                        <th>Importe</th>
                        <th>Créditos</th>
                    </tr>
                </thead>
                <tbody>
                {% for pago in historialPago %}
                    <tr>
                        <td class="slim">
                            {% if pago.valido %}
                                ✔
                            {% else %}
                                ✘
                            {% endif %}
                        </td>
                        <td>{{ pago.metodo }}</td>
                        <td>{{ pago.fecha | date("d/m/Y H:i") }}</td>
                        <td>{{ pago.cantidad }}</td>
                        <td>{{ pago.creditosObtenidos }}</td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="no-data-notice">
                            No has realizado ningún pago aún.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </article>
    </section>

{% endblock %}



{% block javascripts %}

    <script src="{{ asset('script/perfil.js') }}"></script>

{% endblock %}