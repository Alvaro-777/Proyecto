{% extends 'base.html.twig' %}

{% block title %}Configuración de Cuenta{% endblock %}

{% block head %}
    <link rel="stylesheet" href="{{ asset('css/perfil_configuracion.css') }}?v=1.1">
{% endblock %}

{% block cabecera %}Configuración de Cuenta{% endblock %}

{% block body %}

    <section id="profile-config-error-board">

        {% for flashMessage in app.session.flashbag.get('error') %}

            <div id="err-{{ loop.index0 }}" class="error-notice">

                {{ flashMessage }}

                <button class="close-button"
                        onclick="document.getElementById('err-{{ loop.index0 }}').remove();">

                    ✕

                </button>

            </div>

        {% endfor %}

    </section>

    <section class="account-settings">

        <article class="settings-card">

            <header>
                <h2>Cambiar contraseña</h2>
            </header>

            <form action="{{ path('perfil_password_change') }}" id="new-password-form" method="post">

                <label>
                    Contraseña actual
                    <input required type="password" name="old-password">
                </label>

                <label>
                    Nueva contraseña
                    <input required type="password" name="new-password">
                </label>

                <label>
                    Confirmar contraseña
                    <input required type="password" name="confirm-password">
                </label>

                <input type="submit" value="Actualizar contraseña">

            </form>

        </article>


        <article class="settings-card delete-card">

            <header>
                <h2>Borrar cuenta</h2>
            </header>

            <form action="{{ path('perfil_delete_account') }}" method="post" id="delete-account-form">

                <label>
                    Correo
                    <input required type="email" name="email">
                </label>

                <label>
                    Contraseña
                    <input required type="password" name="password">
                </label>

                <label>
                    <span>Escribe <span class="disable-copy" id="captcha"></span></span>
                    <input required type="text" name="captcha">
                </label>

                <input class="delete-button" type="button" value="Eliminar cuenta">

            </form>

        </article>

    </section>

{% endblock %}

{% block javascripts %}
    <script src="{{ asset('script/sweetalert2.all.min.js') }}"></script>
    <script type="module" src="{{ asset('script/patterns.js') }}"></script>
    <script type="module" src="{{ asset('script/perfil_config.js') }}"></script>
{% endblock %}

